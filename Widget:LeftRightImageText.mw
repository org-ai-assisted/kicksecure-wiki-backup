<!--{* Strip ASCII control chars (browsers strip them from URLs before navigation,
       so they can sneak past a literal-scheme blacklist), then block dangerous
       schemes, then html-escape for the attribute. *}-->
<!--{assign var="safeImageLink" value=$imagelink|default:''|regex_replace:'/[\x00-\x1F\x7F]/':''|regex_replace:'/^(javascript|data|vbscript|file)\s*:/i':'#blocked-$1:'|escape:'html'}-->
<!--{assign var="safeImage"     value=$image    |default:''|regex_replace:'/[\x00-\x1F\x7F]/':''|regex_replace:'/^(javascript|data|vbscript|file)\s*:/i':'#blocked-$1:'|escape:'html'}-->

<div class="left-right-image-text <!--{if isset($imageright)}-->image-right<!--{/if}--> <!--{$addToClass|escape:'html'|default:''}-->">
  <div class="image">
    <!--{if isset($imagelink)}--><a href="<!--{$safeImageLink}-->"><!--{/if}-->
      <img src="<!--{$safeImage}-->" alt="<!--{$imageAlt|escape:'html'|default:''}-->"/>
    <!--{if isset($imagelink)}--></a><!--{/if}-->
  </div>
  <div class="text">
    <!--{$text|default:''}-->
  </div>
</div><noinclude>
[[Category:MultiWiki]]
</noinclude>
