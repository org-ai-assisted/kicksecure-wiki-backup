<!--{* WARNING: DO NOT CALL THIS WIDGET DIRECTLY. USE THE TEMPLATES. *}-->

<!--{assign var="id" value=$id|default : ''}-->
<!--{assign var="html" value=$html|default : ''}-->
<!--{assign var="currentMonth" value=$currentMonth|default : ''}-->
<!--{assign var="page" value=$page|default : ''}-->
<!--{assign var="expires" value=$expires|default : ''}-->
<!--{assign var="href" value=$href|default : ''}-->

<!--{* Strip ASCII control chars and block dangerous URL schemes for the optional banner href.
       Browsers strip embedded tab/CR/LF from URLs before navigation, so a literal-scheme
       blacklist alone is bypassable via jav<TAB>ascript:. *}-->
<!--{assign var="safeHref" value=$href|regex_replace:'/[\x00-\x1F\x7F]/' : ''|regex_replace:'/^(javascript|data|vbscript|file)\s*:/i':'#blocked-$1:'|escape:'html'}-->

<!--{assign var="isEndOfYear" value=$id == 'end-of-year'}-->
<!--{assign var="isDecember" value=$currentMonth == 12}-->
<!--{assign var="isBannerTestpage" value=$page == 'TestpageForFlyInNotification'}-->
<!--{assign var="hasMandatoryParams" value=$id !== '' && $html !== ''}-->

<!--{assign var="showBanner" value=true}-->

<!--{if $expires !== '' && $expires <= time() || $isEndOfYear && ! $isDecember && ! $isBannerTestpage}-->
  <!--{assign var="showBanner" value=false}-->
<!--{/if}-->

<!--{if ! $hasMandatoryParams}-->
  <!--{assign var="showBanner" value=true}-->
<!--{/if}-->

<!--{if $showBanner}-->

  <div
    class="sitenotice-banner robots-nocontent<!--{if $isEndOfYear}--> sitenotice-end-of-year donation-panel <!--{if $isBannerTestpage}-->force-show<!--{/if}--><!--{/if}-->"
    data-banner-id="<!--{if $id !== ''}--><!--{$id|escape:'html'}--><!--{else}-->missing-id<!--{/if}-->"
  >
    <!--googleoff: index--><!--noindex-->
    
    <!--{if ! $hasMandatoryParams}-->
    
      <div class="error">Widget SitenoticeBanner Error: Missing mandatory parameters. Required: <code>id</code>, <code>html</code>.</div>
      
    <!--{else}-->
    
      <!--{if $href !== '' }--><a href="<!--{$safeHref}-->"><!--{/if}-->
      
      <!--{$html}-->
      
      <!--{if $href !== '' }--></a><!--{/if}-->
      
    <!--{/if}-->
    
    <!--/noindex--><!--googleon: index-->
  </div>
  
<!--{/if}-->