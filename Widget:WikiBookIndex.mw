<!--{* Strip ASCII control chars and block dangerous URL schemes. See Widget:LeftRightImageText for rationale. *}-->
<!--{assign var="safePreviousUrl" value=$previousUrl|default:''|regex_replace:'/[\x00-\x1F\x7F]/':''|regex_replace:'/^(javascript|data|vbscript|file)\s*:/i':'#blocked-$1:'|escape:'html'}-->
<!--{assign var="safeIndexUrl"    value=$indexUrl   |default:''|regex_replace:'/[\x00-\x1F\x7F]/':''|regex_replace:'/^(javascript|data|vbscript|file)\s*:/i':'#blocked-$1:'|escape:'html'}-->
<!--{assign var="safeNextUrl"     value=$nextUrl    |default:''|regex_replace:'/[\x00-\x1F\x7F]/':''|regex_replace:'/^(javascript|data|vbscript|file)\s*:/i':'#blocked-$1:'|escape:'html'}-->

<span class="wiki-book-index<!--{if ! empty( $for ) }--> wbi-for-<!--{$for|escape:'html'}--><!--{/if}-->">
  <!--{if ! empty( $previousTitle ) }-->
  <a class="prev internal" href="<!--{$safePreviousUrl}-->" title="<!--{$previousTitle|escape:'html'}-->">
    <i class="fa-solid fa-chevron-left fa-fw"></i>
    <span class="text"><!--{$previousTitle|escape:'html'}--></span>
  </a>
  <!--{/if}-->

  <a class="index internal" href="<!--{$safeIndexUrl}-->" title="<!--{$indexTitle|escape:'html'}-->">
    <i class="fa-solid fa-list fa-fw"></i>
    <span class="text"><!--{$indexTitle|escape:'html'}--></span>
  </a>

  <!--{if ! empty( $nextTitle ) }-->
  <a class="next internal" href="<!--{$safeNextUrl}-->" title="<!--{$nextTitle|escape:'html'}-->">
    <i class="fa-solid fa-chevron-right fa-fw"></i>
    <span class="text"><!--{$nextTitle|escape:'html'}--></span>
  </a>
  <!--{/if}-->

  <span class="info">
    <!--{if ! empty( $previousTitle ) }--><span class="prev">Previous page: <!--{$previousTitle|escape:'html'}--></span><!--{/if}-->
    <span class="index">Index page: <!--{$indexTitle|escape:'html'}--></span>
    <!--{if ! empty( $nextTitle ) }--><span class="next">Next page: <!--{$nextTitle|escape:'html'}--></span><!--{/if}-->
  </span>
</span>
<noinclude>
[[Category:MultiWiki]]
</noinclude>
