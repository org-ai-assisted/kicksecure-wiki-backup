<!--{* Strip ASCII control chars and block dangerous URL schemes. See Widget:LeftRightImageText for rationale. *}-->
<!--{assign var="safeImgLink" value=$imgLink|default:''|regex_replace:'/[\x00-\x1F\x7F]/':''|regex_replace:'/^(javascript|data|vbscript|file)\s*:/i':'#blocked-$1:'|escape:'html'}-->
<!--{assign var="safeImgSrc"  value=$imgSrc |default:''|regex_replace:'/[\x00-\x1F\x7F]/':''|regex_replace:'/^(javascript|data|vbscript|file)\s*:/i':'#blocked-$1:'|escape:'html'}-->

<div id="fly-in-notification-panel" role="region" aria-label="Notification panel">
  <div class="inner-wrapper">
    <i class="close-panel fa-solid fa-times" role="button" tabindex="0" aria-label="Close this notification" aria-pressed="false"></i>

    <!--{if ! isset($imgLink) }--><div><!--{else}--><a href="<!--{$safeImgLink}-->" aria-label="Notification image link"><!--{/if}-->
    <img src="<!--{$safeImgSrc}-->" decoding="async" loading="lazy" <!--{if isset($imgHeight) }-->height="<!--{$imgHeight|regex_replace:'/[^0-9]/':''|escape:'html'}-->"<!--{/if}--> <!--{if isset($imgWidth) }-->width="<!--{$imgWidth|regex_replace:'/[^0-9]/':''|escape:'html'}-->"<!--{/if}--> alt="Notification image" />
    <!--{if ! isset($imgLink) }--></div><!--{else}--></a><!--{/if}-->
    <div class="content">
      <div class="headline"><!--{if ! isset($imgLink) }--><!--{$headline|default:''}--><!--{else}--><a href="<!--{$safeImgLink}-->" aria-label="Notification headline link"><!--{$headline|default:''}--></a><!--{/if}--></div>
      <p><!--{$html|default:''}--></p>
    </div>
  </div>
</div>
<noinclude>
  [[Category:MultiWiki]]
</noinclude>
